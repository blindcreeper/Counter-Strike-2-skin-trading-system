# CS2 皮肤量化回测系统 - 环境配置示例
# 复制此文件为 .env 并填入您的实际配置

# ═══════════════════════════════════════════════════
# API 配置
# ═══════════════════════════════════════════════════

# SteamDT API 密钥（用于 Steam 市场数据）
SDT_KEY=your_sdt_api_key_here

# CSQAQ API 令牌（用于国内平台数据）
CSQAQ_TOKEN=your_csqaq_token_here


# ═══════════════════════════════════════════════════
# 回测参数
# ═══════════════════════════════════════════════════

# 初始资金（元）
INITIAL_BALANCE=10000

# 平台手续费比例（小数形式，2.5% = 0.025）
FEE_RATE=0.025

# 最小目标收益率（小数形式，3% = 0.03）
MIN_PROFIT_RATE=0.03

# 最小持仓时间（小时）
MIN_HOLDING_HOURS=1

# 回测数据时间范围（小时）
HOURS_BACK=72


# ═══════════════════════════════════════════════════
# 邮件通知配置（可选）
# ═══════════════════════════════════════════════════

# SMTP 服务器
SMTP_SERVER=smtp.qq.com

# SMTP 端口
SMTP_PORT=587

# 邮箱用户名
SMTP_USER=your_email@qq.com

# 邮箱密码或应用密码
SMTP_PASS=your_email_password

# 接收通知的邮箱
NOTIFY_EMAIL=notification@example.com


# ═══════════════════════════════════════════════════
# 钉钉通知配置（可选）
# ═══════════════════════════════════════════════════

# 钉钉机器人 Webhook URL
# 本地开发时可直接填写，生产环境（GitHub Actions）建议使用 GitHub Secrets
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token

# 钉钉通知启用/禁用
ENABLE_DINGTALK=true

# 钉钉消息通知失败的重试次数（GitHub Actions环境推荐设置3）
DINGTALK_MAX_RETRIES=3

# 钉钉重试延迟（秒）
DINGTALK_RETRY_DELAY=2


# ═══════════════════════════════════════════════════
# 系统配置
# ═══════════════════════════════════════════════════

# Python 编码
PYTHONIOENCODING=utf-8

# 时区
TZ=Asia/Shanghai

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 是否启用调试模式
DEBUG=false
